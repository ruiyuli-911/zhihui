.users-page { padding: 16px; }
.users-filter { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.filter-chip { padding: 6px 14px; border-radius: 16px; background: #f5f5f5; color: #666; font-size: 13px; }
.filter-chip--active { background: #12ae85; color: #fff; }
.users-list { display: flex; flex-direction: column; gap: 12px; }
.user-item { background: #fff; border-radius: 12px; padding: 14px 16px; }
.user-item__top { display: flex; justify-content: space-between; align-items: center; }
.user-item__name { font-size: 16px; font-weight: 600; color: #333; }
.user-item__role { padding: 2px 8px; border-radius: 4px; background: #e8f8f3; color: #12ae85; font-size: 12px; }
.user-item__phone { display: block; font-size: 14px; color: #666; margin-top: 4px; }
.user-item__time { display: block; font-size: 13px; color: #999; margin-top: 2px; }
.user-item__actions { margin-top: 8px; padding-top: 8px; border-top: 1px solid #f0f0f0; }
.user-item__toggle { font-size: 14px; color: #ff4d4f; }
.user-item__toggle--enable { color: #12ae85; }
.empty-state { display: flex; justify-content: center; padding: 60px 0; }
.empty-state__text { color: #999; font-size: 15px; }
