<framework-page
  title="{{pageMeta.title}}"
  role="{{pageMeta.role}}"
  route="{{pageMeta.route}}"
>
  <view class="admin-login-container">
    <view class="admin-login-card">
      <view class="admin-login-title">管理员登录</view>

      <view class="admin-login-field">
        <text class="admin-login-label">手机号</text>
        <input
          class="admin-login-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="admin-login-placeholder"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="admin-login-field">
        <text class="admin-login-label">验证码</text>
        <view class="admin-login-code-row">
          <input
            class="admin-login-input admin-login-code-input"
            type="number"
            maxlength="6"
            placeholder="请输入验证码"
            placeholder-class="admin-login-placeholder"
            value="{{form.code}}"
            bindinput="onCodeInput"
          />
          <button
            class="admin-login-code-btn"
            size="mini"
            disabled="{{sendingCode}}"
            loading="{{sendingCode}}"
            bindtap="handleSendCode"
          >{{codeText}}</button>
        </view>
      </view>

      <button
        class="admin-login-btn"
        type="primary"
        disabled="{{logging}}"
        loading="{{logging}}"
        bindtap="handleLogin"
      >登 录</button>
    </view>
  </view>
</framework-page>
