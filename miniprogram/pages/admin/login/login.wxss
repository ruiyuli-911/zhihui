/* pages/admin/login/login.wxss */
page {
  background-color: #f5f5f5;
}

.admin-login-container {
  display: flex;
  justify-content: center;
  padding: 40px 20px;
  box-sizing: border-box;
}

.admin-login-card {
  width: 100%;
  max-width: 400px;
  background: #ffffff;
  border-radius: 12px;
  padding: 32px 24px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.admin-login-title {
  font-size: 22px;
  font-weight: 700;
  color: #333333;
  text-align: center;
  margin-bottom: 32px;
  letter-spacing: 2px;
}

.admin-login-field {
  margin-bottom: 20px;
}

.admin-login-label {
  display: block;
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
  font-weight: 500;
}

.admin-login-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  font-size: 16px;
  color: #333333;
  background: #fafafa;
  box-sizing: border-box;
  outline: none;
}

.admin-login-input:focus {
  border-color: #12ae85;
  background: #ffffff;
}

.admin-login-placeholder {
  color: #cccccc;
  font-size: 14px;
}

.admin-login-code-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.admin-login-code-input {
  flex: 1;
}

.admin-login-code-btn {
  flex-shrink: 0;
  width: 108px;
  height: 44px;
  padding: 0;
  margin: 0;
  line-height: 44px;
  text-align: center;
  font-size: 13px;
  color: #12ae85;
  background: #e8f8f3;
  border: 1px solid #b8e6d9;
  border-radius: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.admin-login-code-btn[disabled] {
  color: #999999;
  background: #f5f5f5;
  border-color: #e0e0e0;
}

.admin-login-code-btn::after {
  display: none;
}

.admin-login-btn {
  width: 100%;
  height: 46px;
  margin-top: 32px;
  line-height: 46px;
  font-size: 17px;
  font-weight: 600;
  color: #ffffff;
  background: #12ae85;
  border-radius: 23px;
  border: none;
  letter-spacing: 4px;
}

.admin-login-btn[disabled] {
  background: #a0dac8;
}

.admin-login-btn::after {
  display: none;
}
