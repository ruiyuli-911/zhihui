.jobs-page {
  padding: 16px;
}

.jobs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.jobs-count {
  color: var(--text-secondary, #666666);
  font-size: 14px;
}

.btn-publish {
  height: 36px;
  line-height: 36px;
  padding: 0 16px;
  border-radius: 18px;
  background: var(--color-primary, #12ae85);
  color: #ffffff;
  font-size: 13px;
  font-weight: 600;
  border: none;
}

.btn-publish:active {
  opacity: 0.9;
}

.jobs-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.job-item {
  background: #ffffff;
  border-radius: 12px;
  padding: 14px 16px;
}

.job-item__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 4px;
}

.job-item__title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
}

.job-item__title {
  color: var(--text-primary, #333333);
  font-size: 16px;
  font-weight: 600;
}

.job-item__reject {
  margin-top: 8px;
  padding: 8px 10px;
  border-radius: 6px;
  background: #fff2f0;
  border: 1px solid #ffccc7;
}

.job-item__reject--revoked {
  background: #fff7e6;
  border-color: #ffd591;
}

.reject-label {
  color: #ff4d4f;
  font-size: 13px;
  font-weight: 600;
}

.reject-msg {
  color: #ff4d4f;
  font-size: 13px;
}

.reject-label--revoked,
.reject-msg--revoked {
  color: #d46b08;
}

.job-item__salary {
  color: var(--color-orange, #f5a623);
  font-size: 15px;
  font-weight: 700;
  white-space: nowrap;
}

.job-item__meta {
  display: block;
  color: var(--text-secondary, #666666);
  font-size: 13px;
  margin-top: 4px;
}

.job-item__tags {
  display: flex;
  gap: 6px;
  margin-top: 8px;
  flex-wrap: wrap;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  line-height: 20px;
}

.tag--pending {
  background: #fff7e6;
  color: #fa8c16;
}

.tag--approved {
  background: #f6ffed;
  color: #52c41a;
}

.tag--rejected {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag--revoked {
  background: #fff7e6;
  color: #d46b08;
}

.tag--draft {
  background: #f5f5f5;
  color: #999999;
}

.tag--hot {
  background: #fff2f0;
  color: #ff4d4f;
  font-weight: 600;
}

.tag--status {
  background: #e6f7ff;
  color: #1890ff;
}

.tag--closed {
  background: #f5f5f5;
  color: #999999;
}

.job-item__actions {
  display: flex;
  gap: 16px;
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--color-border, #f0f0f0);
}

.action-btn {
  color: var(--color-primary, #12ae85);
  font-size: 14px;
}

.action-btn--danger {
  color: #ff4d4f;
}

.action-btn:active {
  opacity: 0.7;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}

.empty-state__text {
  color: var(--text-hint, #999999);
  font-size: 15px;
  margin-bottom: 20px;
}

.btn-publish-empty {
  height: 44px;
  line-height: 44px;
  padding: 0 32px;
  border-radius: 22px;
  background: var(--color-primary, #12ae85);
  color: #ffffff;
  font-size: 15px;
  font-weight: 600;
  border: none;
}

.btn-publish-empty:active {
  opacity: 0.9;
}
