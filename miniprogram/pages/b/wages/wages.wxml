<framework-page
  title="{{pageMeta.title}}"
  role="{{pageMeta.role}}"
  route="{{pageMeta.route}}"
>
  <view class="bwages-page">

    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-state__text">加载中...</text>
    </view>

    <!-- 云函数未就绪 -->
    <view class="coming-soon" wx:elif="{{!cloudReady}}">
      <view class="coming-soon__icon">🚧</view>
      <text class="coming-soon__title">功能即将上线</text>
      <text class="coming-soon__desc">工资管理功能正在紧锣密鼓地开发中，</text>
      <text class="coming-soon__desc">预计 7月7日 正式上线，敬请期待！</text>
    </view>

    <!-- 工资列表 -->
    <view class="bwages-content" wx:elif="{{cloudReady}}">

      <!-- 顶部操作栏 -->
      <view class="bwages-header">
        <button class="add-btn" bindtap="handleAddWage">+ 录入工资</button>
      </view>

      <!-- Tab 筛选 -->
      <view class="tab-bar">
        <view
          class="tab-item {{tab === item.key ? 'tab-item--active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="key"
          wx:for-item="item"
          data-key="{{item.key}}"
          bindtap="handleTabChange"
        >
          <text>{{item.name}}</text>
        </view>
      </view>

      <!-- 列表 -->
      <view class="bwages-list" wx:if="{{list.length > 0}}">
        <view
          class="bwage-item"
          wx:for="{{list}}"
          wx:key="_id"
          wx:for-item="wage"
          bindtap="handleWageTap"
          data-id="{{wage._id}}"
        >
          <view class="bwage-item__top">
            <text class="bwage-item__name">{{wage.jobseekerName || '未知员工'}}</text>
            <text class="bwage-item__status bwage-item__status--{{wage.status || 'pending'}}">{{wage.statusText}}</text>
          </view>
          <text class="bwage-item__job">{{wage.jobTitle || '—'}} · {{wage.jobseekerPhone || ''}}</text>
          <view class="bwage-item__bottom">
            <text class="bwage-item__amount">{{wage.displayAmount}}</text>
            <text class="bwage-item__meta">{{wage.displayPeriod}}</text>
          </view>
        </view>
      </view>

      <!-- 空列表 -->
      <view class="empty-state" wx:elif="{{!loading}}">
        <text class="empty-state__text">暂无工资记录</text>
        <text class="empty-state__hint">点击上方「录入工资」添加记录</text>
      </view>

    </view>

  </view>
</framework-page>
