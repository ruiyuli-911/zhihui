.glogin-page { padding: 40px 24px; background: linear-gradient(180deg, #1890ff 0%, #096dd9 100%); min-height: 100vh; box-sizing: border-box; }
.glogin-header { text-align: center; padding: 30px 0 40px; }
.glogin-title { display: block; color: #fff; font-size: 28px; font-weight: 700; }
.glogin-desc { display: block; color: rgba(255,255,255,0.8); font-size: 15px; margin-top: 8px; }
.glogin-card { background: #fff; border-radius: 16px; padding: 24px; }
.glogin-field { margin-bottom: 20px; }
.glogin-label { display: block; color: #333; font-size: 14px; font-weight: 600; margin-bottom: 6px; }
.glogin-input { width: 100%; height: 44px; padding: 0 14px; border: 1px solid #e8e8e8; border-radius: 8px; font-size: 14px; color: #333; box-sizing: border-box; background: #fafafa; }
.glogin-code-row { display: flex; gap: 10px; }
.glogin-code { height: 44px; line-height: 44px; padding: 0 16px; border-radius: 8px; background: #1890ff; color: #fff; font-size: 14px; white-space: nowrap; }
.glogin-code--disabled { background: #ccc; }
.glogin-btn { margin-top: 24px; width: 100%; height: 48px; line-height: 48px; border-radius: 24px; background: #fff; color: #1890ff; font-size: 18px; font-weight: 700; text-align: center; border: none; }
.glogin-btn:active { opacity: 0.9; }
