<view class="glogin-page">
  <view class="glogin-header">
    <text class="glogin-title">政府端登录</text>
    <text class="glogin-desc">就业数据管理与政策发布</text>
  </view>
  <view class="glogin-card">
    <view class="glogin-field">
      <text class="glogin-label">手机号</text>
      <input class="glogin-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="glogin-field">
      <text class="glogin-label">验证码</text>
      <view class="glogin-code-row">
        <input class="glogin-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{form.code}}" bindinput="onCodeInput" />
        <view class="glogin-code {{sendingCode ? 'glogin-code--disabled' : ''}}" bindtap="handleSendCode">
          <text>{{codeText}}</text>
        </view>
      </view>
    </view>
  </view>
  <button class="glogin-btn" bindtap="handleLogin" loading="{{logging}}" disabled="{{logging}}">登录</button>
</view>
