.login-page {
  position: relative;
  min-height: 100vh;
  background:
    radial-gradient(circle at 15% 5%, rgba(213, 242, 214, 0.95) 0, rgba(213, 242, 214, 0.35) 20%, rgba(213, 242, 214, 0) 43%),
    radial-gradient(circle at 84% 4%, rgba(208, 234, 248, 0.92) 0, rgba(208, 234, 248, 0.34) 18%, rgba(208, 234, 248, 0) 42%),
    linear-gradient(180deg, #fbfdfc 0%, #ffffff 42%, #ffffff 100%);
  overflow: hidden;
}

.login-bg {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(56rpx);
  opacity: 0.56;
  pointer-events: none;
}

.login-bg--mint {
  top: -140rpx;
  left: -120rpx;
  width: 440rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(188, 240, 224, 0.96) 0%, rgba(188, 240, 224, 0.24) 62%, rgba(188, 240, 224, 0) 100%);
}

.login-bg--blue {
  top: -110rpx;
  right: -134rpx;
  width: 470rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(197, 231, 247, 0.96) 0%, rgba(197, 231, 247, 0.26) 60%, rgba(197, 231, 247, 0) 100%);
}

.login-shell {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 78rpx) 56rpx 64rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 84rpx;
  margin-top: 0;
}

.topbar-back {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 96rpx;
  height: 96rpx;
  margin-left: -12rpx;
  position: relative;
  z-index: 3;
}

.topbar-back__icon {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid #6f7679;
  border-bottom: 3rpx solid #6f7679;
  transform: rotate(45deg);
  margin-left: 8rpx;
  box-sizing: border-box;
}

.topbar-password {
  color: #737b7f;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 400;
}

.hero {
  padding: 84rpx 0 58rpx;
}

.hero-title {
  display: block;
  color: #101010;
  font-size: 64rpx;
  line-height: 1.16;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-subtitle {
  display: block;
  margin-top: 18rpx;
  color: #8d9599;
  font-size: 28rpx;
  line-height: 1.52;
}

.tips-card {
  margin-top: 34rpx;
  padding: 28rpx 30rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid #edf1f0;
}

.tips-card__title {
  display: block;
  color: #222222;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.tips-card__item {
  display: block;
  margin-top: 10rpx;
  color: #7e878b;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.input-row {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 36rpx;
  border-radius: 48rpx;
  background: #f5f6f8;
  box-sizing: border-box;
}

.input-row--split {
  padding-right: 0;
}

.input-control {
  flex: 1;
  height: 100%;
  color: #1a1b1b;
  font-size: 28rpx;
  min-width: 0;
}

.input-placeholder {
  color: #b7bcc1;
  font-size: 28rpx;
}

.code-action-wrap {
  display: flex;
  align-items: center;
  height: 100%;
  flex-shrink: 0;
}

.code-divider {
  width: 2rpx;
  height: 34rpx;
  background: #e1e4e7;
}

.code-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 212rpx;
  height: 100%;
  padding: 0 14rpx;
  color: #33cab7;
  font-size: 26rpx;
  font-weight: 500;
}

.code-action--disabled {
  color: #9aa4a8;
}

.agreement {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
}

.agreement-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid #cdced0;
  border-radius: 50%;
  box-sizing: border-box;
  background: #bfbfbf;
  flex-shrink: 0;
}

.agreement-box--checked {
  border-color: #bfbfbf;
  background: #bfbfbf;
}

.agreement-box__tick {
  color: #ffffff;
  font-size: 15rpx;
  line-height: 1;
  transform: scale(0.86);
}

.agreement-text {
  margin-left: 10rpx;
  color: #4c4f51;
  font-size: 22rpx;
  line-height: 1.5;
}

.submit-btn {
  margin-top: 42rpx;
  height: 100rpx;
  line-height: 100rpx;
  border: none;
  border-radius: 50rpx;
  background: #35c8b8;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}
