<view class="login-page">
  <view class="login-bg login-bg--mint"></view>
  <view class="login-bg login-bg--blue"></view>

  <view class="login-shell">
    <view class="topbar">
      <view class="topbar-back" bindtap="handleBack">
        <view class="topbar-back__icon"></view>
      </view>
    </view>

    <view class="hero">
      <text class="hero-title">验证手机号</text>
      <text class="hero-subtitle">第一次使用将继续登记找工作资料</text>
    </view>

    <view class="form-card">
      <view class="input-row">
        <input
          class="input-control"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="input-placeholder"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="input-row input-row--split">
        <input
          class="input-control"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="input-placeholder"
          value="{{form.code}}"
          bindinput="onCodeInput"
        />
        <view class="code-action-wrap">
          <view class="code-divider"></view>
          <view
            class="code-action {{sendingCode ? 'code-action--disabled' : ''}}"
            bindtap="handleSendCode"
          >
            <text>{{codeText}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tips-card">
      <text class="tips-card__title">验证成功后系统会自动判断</text>
      <text class="tips-card__item">老用户：直接进入首页</text>
      <text class="tips-card__item">第一次使用：继续登记资料</text>
    </view>

    <view class="agreement" bindtap="toggleAgreement">
      <view class="agreement-box {{agreed ? 'agreement-box--checked' : ''}}">
        <text wx:if="{{agreed}}" class="agreement-box__tick">✓</text>
      </view>
      <text class="agreement-text">我已阅读并同意《用户协议》《隐私政策》</text>
    </view>

    <button class="submit-btn" bindtap="handleLogin" loading="{{logging}}" disabled="{{logging}}">
      下一步
    </button>
  </view>
</view>
