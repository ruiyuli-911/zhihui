.cpolicy-page { padding: 16px; }
.cpolicy-list { display: flex; flex-direction: column; gap: 12px; }
.cpolicy-item { background: #fff; border-radius: 12px; padding: 14px 16px; }
.cpolicy-item__title { display: block; font-size: 16px; font-weight: 600; color: #333; }
.cpolicy-item__time { display: block; font-size: 12px; color: #999; margin-top: 4px; }
.cpolicy-item__content { display: block; font-size: 14px; color: #666; line-height: 1.6; margin-top: 8px; }
.empty-state { display: flex; justify-content: center; padding: 60px 0; }
.empty-state__text { color: #999; font-size: 15px; }
