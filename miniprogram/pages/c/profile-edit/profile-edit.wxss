.edit-page {
  min-height: 100vh;
  padding: 20px 16px 32px;
  background: #f6f8f7;
  box-sizing: border-box;
}

.step-card,
.form-section {
  background: #ffffff;
  border-radius: 16px;
}

.step-card {
  padding: 18px 16px;
  margin-bottom: 14px;
}

.step-index {
  display: block;
  color: #12ae85;
  font-size: 13px;
  font-weight: 700;
}

.step-title {
  display: block;
  margin-top: 8px;
  color: #222222;
  font-size: 21px;
  font-weight: 700;
}

.step-desc {
  display: block;
  margin-top: 8px;
  color: #6c757d;
  font-size: 14px;
  line-height: 1.6;
}

.form-section {
  padding: 16px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  color: #333333;
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 48px;
  padding: 0 14px;
  border: 1px solid #e6eaeb;
  border-radius: 12px;
  font-size: 15px;
  color: #333333;
  box-sizing: border-box;
  background: #fafcfc;
}

.choice-row {
  display: flex;
  gap: 10px;
}

.choice-row--wrap {
  flex-wrap: wrap;
}

.choice-column {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.choice-chip,
.choice-row-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0 16px;
  border: 1px solid #dfe6e7;
  border-radius: 12px;
  background: #ffffff;
  color: #495057;
  font-size: 14px;
  box-sizing: border-box;
  transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
}

.choice-row-item {
  justify-content: flex-start;
}

.choice-chip--hover {
  transform: translateY(-1px);
  border-color: #b8d8cf;
}

.choice-chip--active,
.choice-row-item--active {
  border-color: #12ae85;
  background: #e9f8f3;
  color: #0f8d6c;
  font-weight: 600;
}

.upload-box {
  width: 148px;
  height: 100px;
}

.upload-preview {
  width: 148px;
  height: 100px;
  border-radius: 12px;
  border: 1px solid #e8e8e8;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 148px;
  height: 100px;
  border: 1px dashed #d9d9d9;
  border-radius: 12px;
  background: #fafafa;
}

.upload-btn__icon {
  font-size: 28px;
  color: #99a1a7;
}

.upload-btn__text {
  font-size: 13px;
  color: #99a1a7;
  margin-top: 6px;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 48px;
  padding: 0 14px;
  border-radius: 12px;
  background: #fafcfc;
  border: 1px solid #e6eaeb;
}

.switch-label {
  color: #333333;
  font-size: 14px;
}

.form-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
  padding-bottom: 32px;
}

.ghost-btn,
.save-btn {
  flex: 1;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.ghost-btn {
  background: #edf2f1;
  color: #46605b;
}

.save-btn {
  background: #12ae85;
  color: #ffffff;
}
