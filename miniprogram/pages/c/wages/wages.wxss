.wages-page {
  padding: 16px;
  min-height: calc(100vh - 100px);
}

.wages-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.wage-item {
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  cursor: pointer;
}

.wage-item:active {
  opacity: 0.8;
}

.wage-item__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}

.wage-item__title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8px;
}

.wage-item__status {
  flex-shrink: 0;
  display: inline-block;
  padding: 2px 10px;
  border-radius: 999px;
  font-size: 12px;
  line-height: 20px;
  font-weight: 500;
}

.wage-item__status--pending {
  background: #fff7e6;
  color: #fa8c16;
}

.wage-item__status--confirmed {
  background: #e8f8f3;
  color: #12ae85;
}

.wage-item__status--disputed {
  background: #fff2f0;
  color: #ff4d4f;
}

.wage-item__company {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.wage-item__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8px;
  border-top: 1px solid #f5f5f5;
}

.wage-item__amount {
  font-size: 18px;
  font-weight: 700;
  color: #12ae85;
}

.wage-item__period {
  font-size: 13px;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 60px 0;
}

.loading-state__text {
  color: #999;
  font-size: 15px;
}

/* 即将上线 */
.coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 32px;
}

.coming-soon__icon {
  font-size: 64px;
  margin-bottom: 20px;
}

.coming-soon__title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.coming-soon__desc {
  font-size: 15px;
  color: #999;
  line-height: 1.6;
  text-align: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 60px 0;
}

.empty-state__text {
  color: #999;
  font-size: 15px;
}
